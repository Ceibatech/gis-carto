# Serveur API / Contabo: URL MySQL serveur uniquement. Ne jamais exposer au navigateur.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/mulcv_geoarchives"

# Front Vercel: origine publique de l'API Contabo. Laisser vide si front et API sont sur le même serveur.
NEXT_PUBLIC_GEOARCHIVES_API_BASE_URL=""

# Rendu serveur Vercel: optionnel, utilise la même API distante sans exposer de secret.
GEOARCHIVES_API_BASE_URL=""

# API Contabo: origines autorisées à appeler les routes /api depuis le navigateur.
# Exemple production: https://mulcv-geoarchives.vercel.app,https://www.ton-domaine.ci
GEOARCHIVES_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002"

# API Contabo: port du serveur Node derrière Nginx/Caddy.
PORT="4100"

# Authentification applicative: a configurer sur Vercel et Contabo avec des valeurs reelles.
GEOARCHIVES_AUTH_SECRET="change-this-long-random-secret"
GEOARCHIVES_ADMIN_LOGIN="dac01@ceiba-analytics.com"
GEOARCHIVES_ADMIN_PASSWORD="change-me-admin"
GEOARCHIVES_ADMIN_NAME="Administrateur national"
GEOARCHIVES_EXECUTIVE_LOGIN="executif"
GEOARCHIVES_EXECUTIVE_PASSWORD="change-me-executive"
GEOARCHIVES_EXECUTIVE_NAME="Pilotage national"
GEOARCHIVES_AGENT_ACCOUNTS='[{"login":"agent-abidjan","password":"change-me-agent-abidjan","name":"Agent Abidjan"},{"login":"agent-yamoussoukro","password":"change-me-agent-yamoussoukro","name":"Agent Yamoussoukro"}]'
# Compatibilite optionnelle si tu veux garder temporairement un seul agent:
# GEOARCHIVES_AGENT_LOGIN="agent"
# GEOARCHIVES_AGENT_PASSWORD="change-me-agent"
# GEOARCHIVES_AGENT_NAME="Agent registre"

# Les agents doivent ensuite etre crees depuis la page admin: Gestion des comptes.
# Si la table users manque sur une base existante, executer sql/004_create_users.sql une seule fois.

# Admin bootstrap du module CEIBA /inventaire-ceiba.
# Les comptes crees ensuite dans l'interface CEIBA restent limites a ce module.
CEIBA_INVENTORY_ADMIN_LOGIN="ceibac-admin"
CEIBA_INVENTORY_ADMIN_PASSWORD="change-me-ceibac-admin"
CEIBA_INVENTORY_ADMIN_NAME="Administration CEIBAC"
CEIBA_INVENTORY_SESSION_MAX_AGE_SECONDS="43200"

# Email et reinitialisation de mot de passe
RESEND_API_KEY=""
RESEND_FROM_EMAIL="support@ceiba-analytics.com"
PASSWORD_RESET_REDIRECT_URL="https://geoarchiv.ceiba-analytics.com/reset-password"
