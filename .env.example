# Serveur API / Contabo: URL MySQL serveur uniquement. Ne jamais exposer au navigateur.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/mulcv_geoarchives"

# Front Vercel: origine publique de l'API Contabo. Laisser vide si front et API sont sur le m?me serveur.
NEXT_PUBLIC_GEOARCHIVES_API_BASE_URL=""

# Rendu serveur Vercel: optionnel, utilise la m?me API distante sans exposer de secret.
GEOARCHIVES_API_BASE_URL=""

# API Contabo: origines autoris?es ? appeler les routes /api depuis le navigateur.
# Exemple production: https://mulcv-geoarchives.vercel.app,https://www.ton-domaine.ci
GEOARCHIVES_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002"

# API Contabo: port du serveur Node derri?re Nginx/Caddy.
PORT="4000"

# Optionnel: active un endpoint de seed HTTP seulement si tu le cr?es plus tard.
# GEOARCHIVES_ADMIN_TOKEN="change-me"
